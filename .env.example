# ─── Groq ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://juris:juris_secret@localhost:5432/juris_db

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=juris-documents
MINIO_SECURE=false

# ─── FastAPI ──────────────────────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8000

# ─── Next.js (public vars available in browser — never put secrets here) ──────
NEXT_PUBLIC_APP_URL=http://localhost:3000
